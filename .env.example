# MySQL 配置 — 必填
PLS_MYSQL_HOST=your_mysql_host
PLS_MYSQL_PORT=3306
PLS_MYSQL_USER=your_mysql_user
PLS_MYSQL_PASSWORD=your_mysql_password
PLS_MYSQL_DATABASE=your_database_name

# PLS Java 应用 API 地址 — 必填
PLS_API_BASE_URL=http://your_pls_host:8180/pls

# MCP 写操作 API Key（需与 Java 端 application.properties 的 mcp.api.key 一致）
PLS_MCP_API_KEY=your_mcp_api_key

# 日志级别: debug / info
MCP_LOG_LEVEL=info
