# MySQL 配置
PLS_MYSQL_HOST=your-mysql-host
PLS_MYSQL_PORT=3306
PLS_MYSQL_USER=your-mysql-user
PLS_MYSQL_PASSWORD=your-mysql-password
PLS_MYSQL_DATABASE=your-database-name

# Java 应用 API 地址
PLS_API_BASE_URL=http://localhost:8180/pls

# MCP 写操作 API Key（需与 Java 端 application.properties 的 mcp.api.key 一致）
PLS_MCP_API_KEY=your-api-key-here

# MCP Server 调试
MCP_LOG_LEVEL=debug