# ── MySQL 配置（必填）────────────────────────
# 必须配置以下 3 个变量，否则服务无法正常启动
PLS_MYSQL_HOST=your_mysql_host        # MySQL 服务器地址
PLS_MYSQL_PORT=3306                    # MySQL 端口
PLS_MYSQL_USER=your_mysql_user         # MySQL 用户名
PLS_MYSQL_PASSWORD=your_mysql_password # MySQL 密码
PLS_MYSQL_DATABASE=your_database_name  # 数据库名

# ── PLS Java 应用 API 地址（必填）────────────
PLS_API_BASE_URL=http://your_pls_host:8180/pls

# ── MCP 写操作 API Key（可选）────────────────
# 需与 Java 端 application.properties 的 mcp.api.key 一致
# 未配置时写操作可能因鉴权失败，建议生产环境启用
PLS_MCP_API_KEY=your_mcp_api_key

# ── 日志级别（可选）─────────────────────────
# debug: 输出所有调试信息 | info: 仅输出关键信息（默认）
MCP_LOG_LEVEL=info